# 前端环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ===== API配置 =====
# 后端API基础URL
VITE_API_BASE_URL=http://127.0.0.1:8000

# ===== WebSocket配置 =====
# WebSocket连接地址
VITE_WS_URL=ws://127.0.0.1:8000/ws

# ===== 应用配置 =====
# 应用名称
VITE_APP_NAME=DaVinci Coda Strategy

# 开发模式
VITE_DEV_MODE=true

# ===== 语音服务配置 =====
# 注意：不要在前端暴露API密钥！
# 所有需要密钥的API调用应该通过后端代理
# VITE_VOICE_API_KEY=  # 不要使用！
