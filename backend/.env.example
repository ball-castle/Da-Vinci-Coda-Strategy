# 后端环境变量配置模板
# 复制此文件为 .env 并填入实际值

# ===== 应用配置 =====
APP_NAME=Da Vinci Coda API
APP_VERSION=1.0.0
DEBUG=false

# ===== 服务器配置 =====
HOST=127.0.0.1
PORT=8000
RELOAD=true

# ===== CORS配置 =====
# 允许的前端地址，多个地址用逗号分隔
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ===== MCTS算法参数 =====
# 蒙特卡洛树搜索迭代次数
MCTS_ITERATIONS=1000
# 探索常数（UCB1）
MCTS_EXPLORATION_CONSTANT=1.414
# 模拟深度
MCTS_SIMULATION_DEPTH=50
# 计算超时时间（秒）
MCTS_TIMEOUT_SECONDS=5.0

# ===== 日志配置 =====
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===== 语音服务配置 =====
# 讯飞语音API配置（如使用）
VOICE_API_URL=
VOICE_API_KEY=
VOICE_API_SECRET=

# ===== 数据库配置 =====
# 数据库连接字符串（如需要）
# DATABASE_URL=sqlite:///./davinci.db
DATABASE_URL=
